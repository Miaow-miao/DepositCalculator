<Window x:Class="DepositCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DepositCalculator"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="10">
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Сумма" Width="150"/>
                <TextBox x:Name="AmountTextBox" Width="150"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Срок (месяцев)" Width="150"/>
                <TextBox x:Name="MonthsTextBox" Width="150"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Процентная ставка" Width="150"/>
                <TextBox x:Name="RateTextBox" Width="150"/>
            </StackPanel>
            <TextBlock Text="Доход по вкладу =" Margin="0,15,0,5"/>
            <TextBlock x:Name="ResultText" FontSize="16"/>
        </StackPanel>
        <GroupBox Header="Схема начисления %" Grid.Column="1" Margin="10">
            <StackPanel>
                <RadioButton x:Name="SimpleRadio"
                             Content="простые проценты"
                             IsChecked="True"
                             Margin="5"/>
                <RadioButton x:Name="CompoundRadio"
                             Content="сложные проценты"
                             Margin="5"/>
            </StackPanel>
        </GroupBox>
        <Button Content="Вычислить"
                Width="120"
                Height="30"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,20,10"
                Click="Calculate_Click"/>
    </Grid>
</Window>
